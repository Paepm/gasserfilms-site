---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import FacebookIcon from "../components/icons/FacebookIcon.astro";
import InstagramIcon from "../components/icons/InstagramIcon.astro";
import LinkedInIcon from "../components/icons/LinkedInIcon.astro";
import YouTubeIcon from "../components/icons/YouTubeIcon.astro";

// === Replace these values ===
const CONTACT = {
  name: "Christof Gasser",
  email: "christof@gasserfilms.at",
  phoneDisplay: "+43 650 4450 180",
  phoneE164: "+436504450180", // important for tel:
  addressLines: ["Vereinsgasse 1/12", "1020 Wien", "Austria"],
  // This is used for Google Maps query/embed (no API key needed)
  addressQuery: "Vereinsgasse 1/12, 1020 Wien, Austria"
};

const SOCIALS = [
  {
    label: "Facebook",
    href: "https://www.facebook.com",
    svg: FacebookIcon,
  },
  {
    label: "Instagram",
    href: "https://www.instagram.com/gassinho/",
    svg: InstagramIcon,
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/authwall?trk=gf&trkInfo=AQG41E2N8KDVxAAAAZxNwMkwKsu_d4VNT9FuUECn3kS7pi6Ts11-4w4PbRxfYp6LYUIzqWhWnm5_3bx2GpcszyZuYeRhIp6SsdKybTIQGbF-gWO58dgqTa_tmwC2qIsX5u2ohIo=&original_referer=https://www.gasserfilms.at/&sessionRedirect=https%3A%2F%2Fwww.linkedin.com%2Fin%2Fchristof-gasser-16504a33a%2F",
    svg: LinkedInIcon,
  },
  {
    label: "YouTube",
    href: "https://www.youtube.com/@GasserFilms",
    svg: YouTubeIcon,
  },
];

const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(CONTACT.addressQuery)}&output=embed`;
---

<BaseLayout title={`Contact | ${CONTACT.name}`}>
  <Header />

  <main class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <header class="mb-8">
      <h1 class="text-3xl font-semibold md:text-4xl">Kontakt</h1>
      <p class="mt-3 max-w-2xl text-neutral-300">
        Schreib mir gerne für Projekte, Anfragen oder Kooperationen.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-2">
      <!-- Contact Card -->
      <section class="rounded-2xl border border-white/10 bg-neutral-950 p-6">
        <h2 class="text-lg font-semibold">Kontakt</h2>

        <dl class="mt-4 space-y-4 text-sm">
          <div>
            <dt class="text-neutral-400">Name</dt>
            <dd class="mt-1 text-neutral-100">{CONTACT.name}</dd>
          </div>

          <div>
            <dt class="text-neutral-400">E-Mail</dt>
            <dd class="mt-1">
              <a
                class="inline-flex items-center gap-2 text-neutral-100 underline decoration-white/20 underline-offset-4 hover:decoration-white/50  transition-transform duration-150 ease-out hover:scale-115 focus-visible:scale-115 active:scale-105"
                href={`mailto:${CONTACT.email}`}
              >
                {CONTACT.email}
              </a>
            </dd>
          </div>

          <div>
            <dt class="text-neutral-400">Telefon</dt>
            <dd class="mt-1">
              <a
                class="inline-flex items-center gap-2 text-neutral-100 underline decoration-white/20 underline-offset-4 hover:decoration-white/50  transition-transform duration-150 ease-out hover:scale-115 focus-visible:scale-115 active:scale-105"
                href={`tel:${CONTACT.phoneE164}`}
              >
                {CONTACT.phoneDisplay}
              </a>
            </dd>
          </div>

          <div>
            <dt class="text-neutral-400">Adresse</dt>
            <dd class="mt-1 text-neutral-100">
              {CONTACT.addressLines.map((line) => (
                <div>{line}</div>
              ))}
            </dd>
          </div>
        </dl>

        <div class="mt-6">
          <h3 class="text-sm font-semibold text-neutral-200">Socials</h3>
          <div class="mt-3 flex flex-wrap gap-3">
            {SOCIALS.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noreferrer noopener"
                aria-label={s.label}
                class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-neutral-900 px-3 py-2 text-sm text-neutral-200 hover:border-white/25 transition-transform duration-150 ease-out hover:scale-115 focus-visible:scale-115 active:scale-105"
              >
                <s.svg />
                <span>{s.label}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Map Card -->
      <section class="overflow-hidden rounded-2xl border border-white/10 bg-neutral-950">
        <div class="border-b border-white/10 p-6">
          <h2 class="text-lg font-semibold">Standort</h2>
        </div>

        <div class="aspect-[16/10] w-full">
          <div
            class="h-full w-full overflow-hidden rounded-2xl border border-white/10 bg-neutral-900/40"
            data-external-src={mapSrc}
            data-external-title={`Google Maps: ${CONTACT.addressQuery}`}
            data-external-allow=""
          >
            <div class="flex h-full w-full flex-col items-center justify-center gap-3 p-6 text-center">
              <p class="text-sm text-neutral-200">Google Maps ist blockiert.</p>
              <p class="text-xs text-neutral-400">
                Zum Laden musst du externe Medien erlauben (Cookies/DSGVO).
              </p>
              <button
                type="button"
                data-allow-external
                class="rounded-xl bg-white px-4 py-2 text-sm font-medium text-neutral-950 transition transition-transform duration-150 ease-out hover:bg-neutral-200 hover:scale-115 focus-visible:scale-115 active:scale-105"
              >
                Karte laden
              </button>
            </div>
          </div>
        </div>

        <div class="p-6">
          <a
            class="text-sm underline decoration-white/20 underline-offset-4 hover:decoration-white/50 transition-transform duration-150 ease-out hover:scale-115 focus-visible:scale-115 active:scale-105"
            href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(CONTACT.addressQuery)}`}
            target="_blank"
            rel="noreferrer noopener"
          >
            In Google Maps öffnen →
          </a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>