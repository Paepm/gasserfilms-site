---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Contact | Gasser Films">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="text-3xl font-semibold">Anfrageformular</h1>

    <form class="mt-8 grid gap-4 rounded-2xl border border-white/10 p-6">
      <label class="grid gap-2">
        <span class="text-sm text-neutral-300">Name</span>
        <input class="rounded-xl border border-white/10 bg-neutral-900 px-3 py-2" />
      </label>

      <label class="grid gap-2">
        <span class="text-sm text-neutral-300">Email</span>
        <input type="email" class="rounded-xl border border-white/10 bg-neutral-900 px-3 py-2" />
      </label>

      <label class="grid gap-2">
        <span class="text-sm text-neutral-300">Message</span>
        <textarea rows="5" class="rounded-xl border border-white/10 bg-neutral-900 px-3 py-2"></textarea>
      </label>

      <button type="submit" class="mt-2 rounded-xl bg-white px-4 py-2 text-sm font-medium text-neutral-950 hover:bg-neutral-200">
        Send
      </button>

      <p class="text-xs text-neutral-500">
        (Formularlogik kommt später: Formspree oder Cloudflare Function.)
      </p>
    </form>
  </main>
  <Footer />
</BaseLayout>
