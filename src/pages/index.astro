---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Gasser Films">
  <Header />

  <main class="mx-auto max-w-6xl px-4">
    <section class="py-16 md:py-24">
      <p class="text-sm uppercase tracking-widest text-neutral-400">Film & Video Production</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight md:text-6xl">
        Cinematic storytelling for brands & artists.
      </h1>
      <p class="mt-6 max-w-2xl text-base text-neutral-300 md:text-lg">
        Short, clean, modern — like Wix, but faster and yours.
      </p>

      <div class="mt-10 flex gap-3">
        <a href="/portfolio" class="rounded-xl bg-white px-4 py-2 text-sm font-medium text-neutral-950 hover:bg-neutral-200  transition-transform duration-150 ease-out hover:scale-115 focus-visible:scale-115 active:scale-105">
          View Portfolio
        </a>
        <a href="/contact" class="rounded-xl border border-white/15 px-4 py-2 text-sm hover:border-white/30  transition-transform duration-150 ease-out hover:scale-115 focus-visible:scale-115 active:scale-105">
          Contact
        </a>
      </div>
    </section>

    <section class="pb-16">
      <h2 class="text-xl font-semibold">Showreel 2026</h2>

      <!-- Wrapper: limits width + centers -->
      <div class="mt-6 mx-auto max-w-6xl overflow-hidden bg-neutral-950">
        <div class="aspect-video w-full">
          <iframe
            class="h-full w-full"
            src="https://www.youtube-nocookie.com/embed/lYdHO-mGG3E?modestbranding=1&rel=0&controls=1&showinfo=0&fs=1"
            title="Showreel 2026"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
