---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

/**
 * Add more videos here. For now we use placeholders (no thumbnails yet).
 * Later: add thumbnail: "/uploads/thumbnails/xyz.webp"
 * Tip for YouTube: use https://www.youtube-nocookie.com/embed/<VIDEO_ID>
 */
const VIDEOS = [
  {
    title: "Red Bull – Energy Spot",
    year: "2025",
    tags: ["Commercial", "Sports"],
    embedUrl: "https://www.youtube-nocookie.com/embed/VIDEO_ID",
    fallbackLink: "https://www.youtube.com/watch?v=VIDEO_ID",
    // thumbnail: "/uploads/thumbnails/redbull.webp"
  },
  {
    title: "WKO – Corporate Film",
    year: "2024",
    tags: ["Corporate"],
    embedUrl: "https://player.vimeo.com/video/123456789",
    fallbackLink: "https://vimeo.com/123456789",
  },
  {
    title: "Event Recap – Vienna",
    year: "2024",
    tags: ["Event", "Recap"],
    embedUrl: "https://www.youtube-nocookie.com/embed/VIDEO_ID_2",
    fallbackLink: "https://www.youtube.com/watch?v=VIDEO_ID_2",
  },
];

function safeIdFromTitle(title) {
  return title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
}
---

<BaseLayout title="Portfolio | Gasser Films">
  <Header />

  <main class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <header class="mb-10">
      <h1 class="text-3xl font-semibold md:text-4xl">Portfolio</h1>
      <p class="mt-3 max-w-2xl text-neutral-300">
        Auswahl an Projekten & Videos. Klicke eine Karte, um das Video zu öffnen.
      </p>
    </header>

    <!-- Grid -->
    <section class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {VIDEOS.map((v) => {
        const dialogId = `video-${safeIdFromTitle(v.title)}`;
        return (
          <article class="group overflow-hidden rounded-2xl border border-white/10 bg-neutral-950 transition hover:border-white/25 hover:shadow-[0_0_0_1px_rgba(255,255,255,0.08)]">
            <!-- Placeholder / Thumbnail area -->
            <button
              type="button"
              class="relative block w-full"
              aria-label={`Open video: ${v.title}`}
              data-open={dialogId}
            >
              <div class="aspect-video w-full bg-neutral-900/70">
                {/* If you later add v.thumbnail, replace this with <img ... /> */}
                <div class="flex h-full w-full items-center justify-center">
                  <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-neutral-950/60 px-4 py-3 text-sm text-neutral-200 backdrop-blur">
                    <span class="inline-block h-2.5 w-2.5 rounded-full bg-white/40"></span>
                    <span>Video preview</span>
                    <span class="text-neutral-400">(coming soon)</span>
                  </div>
                </div>
              </div>

              <!-- Hover overlay -->
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/60 via-black/0 to-black/0 opacity-0 transition group-hover:opacity-100"></div>
            </button>

            <!-- Meta -->
            <div class="p-5">
              <div class="flex items-start justify-between gap-3">
                <h2 class="text-base font-semibold text-neutral-100">{v.title}</h2>
                <span class="shrink-0 text-xs text-neutral-400">{v.year}</span>
              </div>

              {v.tags?.length ? (
                <div class="mt-3 flex flex-wrap gap-2">
                  {v.tags.map((t) => (
                    <span class="rounded-full border border-white/10 bg-neutral-900 px-2.5 py-1 text-xs text-neutral-300">
                      {t}
                    </span>
                  ))}
                </div>
              ) : null}

              <div class="mt-4">
                <button
                  type="button"
                  data-open={dialogId}
                  class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-neutral-900/60 px-3 py-2 text-sm text-neutral-200 transition hover:border-white/25 hover:text-white"
                >
                  Watch
                  <span aria-hidden="true">→</span>
                </button>
              </div>
            </div>

            <!-- Modal (native <dialog>) -->
            <dialog
              id={dialogId}
              class="backdrop:bg-black/70 backdrop:backdrop-blur-sm rounded-2xl border border-white/10 bg-neutral-950 text-neutral-100 w-[min(920px,92vw)] p-0"
            >
              <div class="flex items-center justify-between gap-3 border-b border-white/10 p-4">
                <div class="min-w-0">
                  <p class="truncate text-sm font-semibold">{v.title}</p>
                  <p class="text-xs text-neutral-400">{v.year}</p>
                </div>

                <form method="dialog">
                  <button
                    class="rounded-xl border border-white/10 bg-neutral-900/60 px-3 py-2 text-sm text-neutral-200 hover:border-white/25 hover:text-white"
                    aria-label="Close"
                  >
                    Close
                  </button>
                </form>
              </div>

              <div class="p-4">
                {v.embedUrl ? (
                <div class="aspect-video overflow-hidden rounded-2xl border border-white/10 bg-black">
                  <div
                    class="h-full w-full"
                    data-external-src={v.embedUrl}
                    data-external-title={`Video: ${v.title}`}
                    data-external-allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  >
                    <div class="flex h-full w-full flex-col items-center justify-center gap-3 p-6 text-center">
                      <p class="text-sm text-neutral-200">Video ist blockiert.</p>
                      <p class="text-xs text-neutral-400">
                        Zum Abspielen musst du externe Medien erlauben.
                      </p>
                      <button
                        type="button"
                        data-allow-external
                        class="rounded-xl bg-white px-4 py-2 text-sm font-medium text-neutral-950 hover:bg-neutral-200"
                      >
                        Video laden
                      </button>
                    </div>
                  </div>
                </div>
              ) : (
                <div class="rounded-2xl border border-white/10 bg-neutral-900/30 p-6 text-sm text-neutral-300">
                  Dieses Video ist nicht direkt eingebettet.
                </div>
              )}

                {v.fallbackLink ? (
                  <div class="mt-4 flex items-center justify-between gap-3">
                    <a
                      class="text-sm underline decoration-white/20 underline-offset-4 hover:decoration-white/50"
                      href={v.fallbackLink}
                      target="_blank"
                      rel="noreferrer noopener"
                    >
                      Open in new tab →
                    </a>
                    <p class="text-xs text-neutral-500">
                      (Später: Consent Gate für externe Medien)
                    </p>
                  </div>
                ) : null}
              </div>
            </dialog>
          </article>
        );
      })}
    </section>
  </main>

  <Footer />

  <!-- Tiny vanilla JS to open/close dialogs -->
  <script is:inline>
    (() => {
      const openButtons = document.querySelectorAll("[data-open]");
      openButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.getAttribute("data-open");
          const dlg = document.getElementById(id);
          if (dlg && typeof dlg.showModal === "function") dlg.showModal();
        });
      });

      // Close dialog when clicking on backdrop (outside the dialog content)
      document.querySelectorAll("dialog").forEach((dlg) => {
        dlg.addEventListener("click", (e) => {
          const rect = dlg.getBoundingClientRect();
          const clickedInDialog =
            e.clientX >= rect.left &&
            e.clientX <= rect.right &&
            e.clientY >= rect.top &&
            e.clientY <= rect.bottom;
          if (!clickedInDialog) dlg.close();
        });
      });
    })();
  </script>
</BaseLayout>