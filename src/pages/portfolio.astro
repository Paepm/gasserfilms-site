---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

/**
 * Portfolio (YouTube, no modal):
 * - Hover (desktop, consent): thumbnail -> muted autoplay preview iframe (no controls)
 * - Click: replaces tile with normal player (autoplay, controls)
 * - Double-click: tries fullscreen (best effort)
 *
 * Consent key: gf_consent_v1 (externalMedia)
 */

const VIDEOS = [
  { id: "lYdHO-mGG3E", title: "Showreel 2026", category: "Cinematography" },
  { id: "gA6KDJqHygM", title: "The Rumperts SBÄM Records", category: "Musik" },
  { id: "EzXa06qVOns", title: "Seaside King – Drifting Away", category: "Musik" },
  { id: "FVjHOYxBESw", title: "Guttaring Enduro - 21.06.2017", category: "Event" },
  { id: "8FC8hM-MZj8", title: "WA 4", category: "Event" },
  { id: "dzWBQsFISVA", title: "Versuch", category: "Art" },
];

const thumbUrl = (id) => `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;

// Hover preview: muted + autoplay + no controls
const previewEmbed = (id) =>
  `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&mute=1&controls=0&modestbranding=1&rel=0&playsinline=1`;

// Click playback: autoplay + controls
const playEmbed = (id) =>
  `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&mute=0&controls=1&modestbranding=1&rel=0&playsinline=1`;
---

<BaseLayout title="Portfolio | Gasser Films">
  <Header />

  <main class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <header class="mb-10 text-center">
      <h1 class="text-3xl font-semibold">Portfolio</h1>
    </header>

    <!-- Grid -->
    <section class="grid gap-4 sm:grid-cols-2">
      {VIDEOS.map((v) => (
        <button
          type="button"
          class="group relative overflow-hidden rounded-2xl border border-white/10 bg-black text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-white/30"
          data-tile
          data-id={v.id}
          data-title={v.title}
          data-category={v.category}
          data-preview={previewEmbed(v.id)}
          data-play={playEmbed(v.id)}
          aria-label={`Play video: ${v.title}`}
        >
          <div class="relative aspect-video w-full">
            <img
              src={thumbUrl(v.id)}
              alt={v.title}
              loading="lazy"
              class="h-full w-full object-cover opacity-90 transition group-hover:opacity-100"
            />

            <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/65 to-transparent"></div>

            <div class="pointer-events-none absolute bottom-3 left-3 right-3">
              <p class="text-sm font-semibold text-white">{v.title}</p>
              <p class="mt-0.5 text-xs text-white/70">{v.category}</p>
            </div>
          </div>
        </button>
      ))}
    </section>
  </main>

  <Footer />

  <script is:inline>
    (() => {
      const CONSENT_KEY = "gf_consent_v1";
      const tiles = document.querySelectorAll("[data-tile]");

      // store original tile innerHTML so we can restore after hover preview
      const restoreMap = new WeakMap();

      function getConsent() {
        try {
          const raw = localStorage.getItem(CONSENT_KEY);
          return raw ? JSON.parse(raw) : null;
        } catch {
          return null;
        }
      }

      function externalAllowed() {
        return getConsent()?.externalMedia === true;
      }

      function mountPlayer(tile) {
        const src = tile.getAttribute("data-play");
        const title = tile.getAttribute("data-title") || "Video";
        const category = tile.getAttribute("data-category") || "";

        tile.setAttribute("data-mounted", "1");

        tile.innerHTML = `
          <div class="relative aspect-video w-full">
            <iframe
              class="h-full w-full"
              src="${src}"
              title="${title}"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>

            <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/65 to-transparent"></div>
            <div class="pointer-events-none absolute bottom-3 left-3 right-3">
              <p class="text-sm font-semibold text-white">${title}</p>
              <p class="mt-0.5 text-xs text-white/70">${category}</p>
            </div>
          </div>
        `;
      }

      function showBlocked(tile) {
        const title = tile.getAttribute("data-title") || "Video";

        tile.innerHTML = `
          <div class="flex aspect-video w-full items-center justify-center p-6 text-center">
            <div class="max-w-sm">
              <p class="text-sm font-semibold text-neutral-100">${title}</p>
              <p class="mt-2 text-xs text-neutral-400">
                Zum Abspielen musst du externe Medien erlauben.
              </p>
              <button
                type="button"
                data-allow-external
                class="mt-4 rounded-xl bg-white px-4 py-2 text-sm font-medium text-neutral-950 hover:bg-neutral-200"
              >
                Video laden
              </button>
            </div>
          </div>
        `;
      }

      function mountPreview(tile) {
        const src = tile.getAttribute("data-preview");
        const title = tile.getAttribute("data-title") || "";
        const category = tile.getAttribute("data-category") || "";

        // IMPORTANT: pointer-events-none so clicks still go to the BUTTON (tile)
        tile.innerHTML = `
          <div class="relative aspect-video w-full">
            <iframe
              class="h-full w-full pointer-events-none"
              src="${src}"
              loading="lazy"
              allow="autoplay; encrypted-media; picture-in-picture"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>

            <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/65 to-transparent"></div>
            <div class="pointer-events-none absolute bottom-3 left-3 right-3">
              <p class="text-sm font-semibold text-white">${title}</p>
              <p class="mt-0.5 text-xs text-white/70">${category}</p>
            </div>
          </div>
        `;
      }

      function tryFullscreen(tile) {
        const iframe = tile.querySelector("iframe");
        const target = iframe || tile;

        if (target && target.requestFullscreen) {
          target.requestFullscreen().catch(() => {});
        }
      }

      tiles.forEach((tile) => {
        // Hover: show preview (only if not mounted + consent + real hover device)
        tile.addEventListener("pointerenter", () => {
          if (tile.getAttribute("data-mounted") === "1") return;
          if (!externalAllowed()) return;
          if (window.matchMedia("(hover: none)").matches) return;

          if (!restoreMap.has(tile)) restoreMap.set(tile, tile.innerHTML);
          mountPreview(tile);
        });

        tile.addEventListener("pointerleave", () => {
          if (tile.getAttribute("data-mounted") === "1") return;
          const original = restoreMap.get(tile);
          if (original) tile.innerHTML = original;
        });

        // Click: mount normal player (controls)
        tile.addEventListener("click", () => {
          if (tile.getAttribute("data-mounted") === "1") return;

          if (!externalAllowed()) {
            showBlocked(tile);
            return;
          }

          mountPlayer(tile);

          // optional: trigger global logic
          document.dispatchEvent(new CustomEvent("consentchange", { detail: getConsent() || {} }));
        });

        // Double click: fullscreen (best effort)
        tile.addEventListener("dblclick", (e) => {
          e.preventDefault();
          if (tile.getAttribute("data-mounted") !== "1") return;
          tryFullscreen(tile);
        });
      });
    })();
  </script>
</BaseLayout>