---
import FacebookIcon from "../components/icons/FacebookIcon.astro";
import InstagramIcon from "../components/icons/InstagramIcon.astro";
import LinkedInIcon from "../components/icons/LinkedInIcon.astro";
import YouTubeIcon from "../components/icons/YouTubeIcon.astro";

const partners = [
  { name: "ORF", src: "/imgs/orf.png", href: "https://orf.at" },
  { name: "Licht ins Dunkel", src: "/imgs/lichtinsdunkel.png", href: "https://lichtinsdunkel.orf.at" },
  { name: "Stadt Wien", src: "/imgs/stadtwien.png", href: "https://www.wien.gv.at" },
  { name: "OBI", src: "/imgs/obi.png", href: "https://www.obi.at" },
  { name: "Red Bull", src: "/imgs/redbull.png", href: "https://www.redbull.com" },
  { name: "WKO", src: "/imgs/wko.png", href: "https://www.wko.at" },
  // TODO: fix link
  { name: "Böschreisen", src: "/imgs/böschreisen.png", href: "#" },
  { name: "Pro7", src: "/imgs/pro7.png", href: "https://www.prosiebensat1.com/" },
  { name: "ATV", src: "/imgs/atv.png", href: "https://www.atv.at" },
  { name: "Land Rover", src: "/imgs/landrover.png", href: "https://www.landrover.com" },
  { name: "Puls4", src: "/imgs/puls4.png", href: "https://www.prosiebensat1puls4.com/" },
];

const SOCIALS = [
  { label: "Instagram", href: "https://www.instagram.com/gassinho/", svg: InstagramIcon },
  { label: "YouTube", href: "https://www.youtube.com/@GasserFilms", svg: YouTubeIcon },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/christof-gasser-16504a33a/", svg: LinkedInIcon },
  // optional:
  { label: "Facebook", href: "https://www.facebook.com/christof.gasser.10/?locale=de_DE", svg: FacebookIcon },
];
---

<footer class="mt-16 border-t border-white/10">
  <div class="mx-auto max-w-6xl px-4 py-10 text-sm text-neutral-400">
    <!-- Top: Social icons + Partners -->
    <section class="mb-10 grid gap-8 md:grid-cols-12">
      <!-- Socials: icons only -->
      <aside class="md:col-span-3">
        <div class="flex items-center gap-4">
          <div class="h-px flex-1 bg-white/10"></div>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-neutral-300">
            Socials
          </h2>
          <div class="h-px flex-1 bg-white/10"></div>
        </div>

        <div class="mt-4 flex flex-wrap gap-1 items-center justify-evenly">
          {SOCIALS.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noreferrer noopener"
              aria-label={s.label}
              title={s.label}
              class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-neutral-950/30 text-neutral-200 transition hover:border-white/25 hover:bg-neutral-900/40 hover:text-white hover:scale-110 focus-visible:scale-110 active:scale-95"
            >
              <s.svg />
            </a>
          ))}
        </div> 
      </aside>

      <!-- Partners -->
      <div class="md:col-span-9">
        <div class="flex items-center gap-4">
          <div class="h-px flex-1 bg-white/10"></div>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-neutral-300">
            Partner
          </h2>
          <div class="h-px flex-1 bg-white/10"></div>
        </div>

        <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
          {partners.map((p) => (
            <a
              href={p.href}
              target="_blank"
              rel="noreferrer noopener"
              aria-label={p.name}
              title={p.name}
              class="group flex h-16 items-center justify-center rounded-2xl border border-white/10 bg-neutral-950/30 text-neutral-200 transition hover:border-white/25 hover:bg-neutral-900/40 hover:text-white hover:scale-110 focus-visible:scale-110 active:scale-95"
            >
              <img
                src={p.src}
                alt={p.name}
                loading="lazy"
                class="max-h-9 w-full object-contain opacity-90 transition group-hover:opacity-100"
              />
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Bottom -->
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <p>© Gasser Films</p>

      <div class="flex flex-wrap gap-4">
        <a
          class="cursor-pointer transition-transform duration-150 ease-out hover:text-white hover:scale-115 focus-visible:scale-115 active:scale-105"
          href="/imprint"
        >
          Impressum
        </a>
        <a
          class="cursor-pointer transition-transform duration-150 ease-out hover:text-white hover:scale-115 focus-visible:scale-115 active:scale-105"
          href="/privacy"
        >
          Datenschutz
        </a>
        <a
          href="#"
          role="button"
          class="cursor-pointer transition-transform duration-150 ease-out hover:text-white hover:scale-115 focus-visible:scale-115 active:scale-105"
          onclick="window.__openCookieSettings && window.__openCookieSettings(); return false;"
        >
          Cookie-Einstellungen
        </a>
      </div>
    </div>
  </div>
</footer>