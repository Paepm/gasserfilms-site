---
import "../styles/global.css";
import ConsentBanner from "../components/ConsentBanner.astro";
import PrivacyModal from "../components/PrivacyModal.astro";
import ImprintModal from "../components/ImprintModal.astro";

const { title = "Gasser Films", description = "" } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="icon" href="/favicon.ico" />
  </head>

  <body class="relative min-h-screen bg-neutral-950 text-neutral-100">
    <!-- Background glow (alternative, stronger + more cinematic) -->
  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <!-- subtle global vignette -->
    <div class="absolute inset-0 bg-[radial-gradient(1200px_600px_at_50%_-10%,rgba(244,63,94,0.10),transparent_60%),radial-gradient(900px_500px_at_10%_110%,rgba(56,189,248,0.10),transparent_60%),radial-gradient(800px_500px_at_90%_120%,rgba(168,85,247,0.10),transparent_60%)]"></div>

    <!-- top hero glow -->
    <div class="absolute -top-24 left-1/2 h-[520px] w-[1200px] -translate-x-1/2 rounded-full bg-gradient-to-r from-fuchsia-500/25 via-red-500/15 to-orange-400/20 blur-3xl"></div>

    <!-- bottom left glow -->
    <div class="absolute bottom-[-260px] left-[-260px] h-[640px] w-[640px] rounded-full bg-gradient-to-tr from-sky-500/18 via-indigo-500/14 to-purple-500/18 blur-3xl"></div>

    <!-- small accent glow (optional) -->
    <div class="absolute top-[35%] right-[-220px] h-[420px] w-[420px] rounded-full bg-gradient-to-tr from-amber-400/10 via-orange-500/10 to-fuchsia-500/12 blur-3xl"></div>
  </div>

    <slot />

    <!-- Cookie / Consent Banner -->
    <ConsentBanner />

    <!-- Privacy Modal -->
    <PrivacyModal />

    <!-- Imprint Modal -->
    <ImprintModal />

    <!-- External media gating (YouTube / Google Maps) -->
    <script is:inline>
      (() => {
        const CONSENT_KEY = "gf_consent_v1";

        function getConsent() {
          try {
            const raw = localStorage.getItem(CONSENT_KEY);
            return raw ? JSON.parse(raw) : null;
          } catch {
            return null;
          }
        }

        function mountEmbeds() {
          const consent = getConsent();
          const allowed = consent?.externalMedia === true;

          if (!allowed) return;

          document.querySelectorAll("[data-external-src]").forEach((host) => {
            const alreadyMounted = host.getAttribute("data-mounted") === "1";
            if (alreadyMounted) return;

            const src = host.getAttribute("data-external-src");
            if (!src) return;

            const title = host.getAttribute("data-external-title") || "External content";
            const allow = host.getAttribute("data-external-allow") || "";

            const iframe = document.createElement("iframe");
            iframe.src = src;
            iframe.title = title;
            iframe.loading = "lazy";
            iframe.allowFullscreen = true;
            iframe.referrerPolicy = "no-referrer-when-downgrade";
            if (allow) iframe.setAttribute("allow", allow);
            iframe.className = "h-full w-full";

            host.innerHTML = "";
            host.appendChild(iframe);
            host.setAttribute("data-mounted", "1");
          });
        }

        // Mount on load (if user already consented earlier)
        window.addEventListener("DOMContentLoaded", mountEmbeds);

        // Mount whenever consent changes (ConsentBanner dispatches this event)
        document.addEventListener("consentchange", mountEmbeds);

        // If user clicks "Load external media" button in a placeholder, enable external media
        document.addEventListener("click", (e) => {
          const btn = e.target.closest("[data-allow-external]");
          if (!btn) return;

          const consent = { necessary: true, externalMedia: true };
          localStorage.setItem(CONSENT_KEY, JSON.stringify(consent));
          document.dispatchEvent(new CustomEvent("consentchange", { detail: consent }));
          mountEmbeds();
        });
      })();
    </script>
  </body>
</html>